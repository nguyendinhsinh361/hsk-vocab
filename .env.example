# Cấu hình cho docker compose (đổi tên thành .env ở thư mục gốc).
# MySQL nằm ở SERVER RIÊNG — điền connection string tới server đó.

# DB ở server khác:
DATABASE_URL="mysql://user:password@db-host:3306/migii_hsk_vocab"
# Nếu DB chạy trên CHÍNH máy đang chạy docker, dùng host.docker.internal:
# DATABASE_URL="mysql://root:root@host.docker.internal:3306/migii_hsk_vocab"

# Bí mật ký JWT (BẮT BUỘC đổi ở production).
JWT_SECRET="doi-secret-nay-o-production"

# Origin của frontend (CORS). Đổi thành domain thật khi deploy.
FRONTEND_URL="http://localhost:3000"
