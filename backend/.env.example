# Database — MySQL 8.0 CHẠY NGOÀI (không dùng docker ở dự án này)
DATABASE_URL="mysql://root:root@localhost:3306/migii_hsk"

# Redis — chạy bằng docker-compose (xem ../docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# Fake data — BẬT (true) để FE chạy khi chưa có DB. Khi đã seed MySQL → đặt false.
USE_FAKE_DATA=true

# Server
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Thư mục assets tĩnh (audio/image) — PROD đặt /app/assets (nơi mount volume)
# ASSETS_DIR="/app/assets"
