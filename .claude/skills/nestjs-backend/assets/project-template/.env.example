NODE_ENV=development
PORT=3000
# database (Prisma): postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
# auth — generate: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
# cache driver: redis (shared, use in prod/staging) | memory (zero-infra, the default)
CACHE_DRIVER=redis
CACHE_TTL_SECONDS=60
# redis — only required when CACHE_DRIVER=redis (leave password empty for local docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# cors: comma-separated origins
CORS_ORIGINS=http://localhost:5173
# observability
LOG_LEVEL=debug
